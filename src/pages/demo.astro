---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Demo — SpaRcle Engine">
  <section class="demo-page" style="padding: 10px 10px 10px;">
    <div class="glass anim-float-in demo-shell">
      <div class="demo-header">
        <div class="demo-dots" aria-hidden="true">
          <span class="demo-dot demo-dot--red"></span>
          <span class="demo-dot demo-dot--yellow"></span>
          <span class="demo-dot demo-dot--green"></span>
        </div>
        <div class="demo-title">
          <span class="font-montserrat font-semibold tracking-tight">SREngine Web Demo</span>
          <span class="font-jbmono" style="color: rgba(var(--muted), 1); font-size: 12px;">WASM</span>
        </div>
        <div class="demo-hint font-jbmono">
          Click the canvas to focus · <span class="kbd">Esc</span> to close menus
        </div>
      </div>

      <div class="demo-frame" id="srengine-frame">
        <div class="demo-status font-jbmono" id="srengine-status" role="status" aria-live="polite">
          Loading demo…
        </div>
        <canvas id="srengine-canvas" tabindex="0"></canvas>
      </div>

      <div class="demo-footer font-jbmono" style="color: rgba(var(--muted), 1);">
        If the demo doesn’t start, check that your browser supports WebAssembly + WebGL.
      </div>
    </div>
  </section>

  <script is:inline src="/demo/SREngine.js"></script>
  <script is:inline>
    (function () {
      const status = document.getElementById('srengine-status');
      const canvas = document.getElementById('srengine-canvas');
      if (!(canvas instanceof HTMLCanvasElement)) return;

      canvas.addEventListener('click', () => canvas.focus());
      canvas.addEventListener('contextmenu', (e) => e.preventDefault());

      const setStatus = (text) => {
        if (!status) return;
        status.textContent = text;
        status.toggleAttribute('data-hidden', !text);
      };

      const boot = () => {
        const api = window.SREngine;
        if (typeof api !== 'function') {
          setStatus('Failed to load engine script.');
          return;
        }

        setStatus('Loading demo…');

        api({
          canvas,

          locateFile(path, prefix) {
            return "/demo/" + path;
          }
        })
          .then(() => setStatus(''))
          .catch((err) => {
            console.error(err);
            setStatus('Failed to start demo. See console for details.');
          });
      };

      // Ensure the external script has executed.
      if (typeof window.SREngine === 'function') boot();
      else window.addEventListener('load', boot, { once: true });
    })();
  </script>

  <style>
    .demo-shell {
      border-radius: var(--radius);
      padding: 16px;
      margin: 0 auto;
      box-shadow: var(--shadow);
      width: 100%;
      height: 90%;
      margin: 0;
      display: flex;
      flex-direction: column;
    }

    .demo-header {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 4px 4px 10px;
      border-bottom: 1px solid rgba(var(--border), 0.65);
    }

    .demo-dots {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 6px 8px;
      border-radius: 999px;
      background: rgba(var(--surface), 0.55);
      border: 1px solid rgba(var(--border), 0.65);
    }

    .demo-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.35) inset;
    }
    .demo-dot--red { background: rgba(255, 95, 86, 1); }
    .demo-dot--yellow { background: rgba(255, 189, 46, 1); }
    .demo-dot--green { background: rgba(39, 201, 63, 1); }

    .demo-title {
      display: inline-flex;
      align-items: baseline;
      gap: 10px;
      min-width: 0;
    }

    .demo-hint {
      margin-left: auto;
      font-size: 12px;
      color: rgba(var(--muted), 1);
      display: none;
      white-space: nowrap;
    }

    @media (min-width: 820px) {
      .demo-hint { display: inline; }
    }

    .demo-frame {
      position: relative;
      margin-top: 14px;
      border-radius: calc(var(--radius) - 6px);
      border: 1px solid rgba(var(--border), 0.85);
      background:
        radial-gradient(900px 420px at 15% 10%, rgba(var(--accent), 0.10), transparent 60%),
        radial-gradient(760px 420px at 85% 5%, rgba(var(--accent-2), 0.10), transparent 60%),
        rgba(var(--surface), 0.35);
      overflow: hidden;
    }

    .demo-frame::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.28;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.06), transparent 26%),
        radial-gradient(900px 280px at 20% 0%, rgba(var(--accent), 0.10), transparent 60%);
    }

    .demo-status {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: rgba(var(--text), 0.92);
      background: rgba(0, 0, 0, 0.25);
      backdrop-filter: blur(6px);
      z-index: 2;
      text-align: center;
      padding: 14px;
      font-size: 13px;
      letter-spacing: 0.01em;
    }

    .demo-page {
        width: 100vw;
        height: 100vh;
        padding: 0;
    }

    .demo-status[data-hidden] {
      opacity: 0;
      pointer-events: none;
      transition: opacity 220ms ease;
    }

    #srengine-canvas {
      position: relative;
      z-index: 1;
      display: block;
      width: 100%;
      height: 100%;
      outline: none;
      touch-action: none;
      background: rgba(0, 0, 0, 0.25);
    }

    .demo-footer {
      padding: 12px 4px 2px;
      font-size: 12px;
      line-height: 1.5;
    }
  </style>
</Layout>

