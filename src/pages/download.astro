---
import Layout from '../layouts/Layout.astro';
import DownloadCard from '../components/DownloadCard.astro';
---

	<Layout title='Downloads'>
		<section class="section__download">
        <div class="download__container flex flex-col justify-center items-center px-5 py-10 sm:p-7 md:p-12 lg:p-24 mt-10">
            <h1 class="font-montserrat font-semibold tracking-tight text-4xl sm:text-6xl mb-6 anim-float-in">Download SpaRcle Engine</h1>
            <p class="font-jbmono text-sm sm:text-base text-white/75 mb-10 max-w-[62ch] text-center anim-float-in anim-delay-1">Grab a release build or build from source. The engine is evolving quickly; the docs cover the current setup steps.</p>
            <div class="download__body flex flex-wrap">
                <DownloadCard>
                    <div class="card__container flex flex-col sm:flex-row">
                        <div class="card__left mr-5 mb-5 sm:mb-0">
                            <img src="/icons/arch-white.png" class="max-w-14" alt="Arch logo">
                        </div>
                        <div class="card__right">
                            <h2 class="OS__version text-2xl font-bold mb-2">For Linux?</h2>
                            <p class="download__description pb-5">If you are using Linux, you can download or build SREngine yourself using one of the following methods</p>
                            <div class="card__buttons flex flex-col sm:flex-row">
                                <a href="https://github.com/SpaRcle-Studio/SREngine/releases" class="btn-primary focus-ring font-montserrat mb-3 sm:mb-0 sm:mr-3">Releases<span aria-hidden="true" style="opacity: 0.8; font-family: 'JetBrains Mono', monospace;">→</span></a>
                                <a href="https://github.com/SpaRcle-Studio/SREngine/blob/dev/Documentation/LinuxBuild.md" class="btn-secondary focus-ring font-montserrat mb-3 sm:mb-0 sm:mr-3">Build from source</a>
                                <a href="https://github.com/flathub/flathub/pull/5482" class="btn-secondary focus-ring font-montserrat">Flathub</a>
                            </div>
                        </div>
                    </div>
                </DownloadCard>
                <DownloadCard>
                    <div class="card__container flex flex-col sm:flex-row">
                        <div class="card__left mr-5 mb-5 sm:mb-0">
                            <img src="/icons/windows-white.png" class="max-w-14" alt="Windows logo">
                        </div>
                        <div class="card__right">
                            <h2 class="OS__version text-2xl font-bold mb-2">For Windows?</h2>
                            <p class="download__description pb-5">If you are using Windows, you can download or build SREngine yourself using one of the following methods</p>
                            <div class="card__buttons flex flex-row">
                                <a href="https://github.com/SpaRcle-Studio/SREngine/releases" class="btn-primary focus-ring font-montserrat mr-3">Releases<span aria-hidden="true" style="opacity: 0.8; font-family: 'JetBrains Mono', monospace;">→</span></a>
                                <a href="https://github.com/SpaRcle-Studio/SREngine/blob/dev/Documentation/WindowsBuild.md" class="btn-secondary focus-ring font-montserrat">Build from source</a>
                            </div>
                        </div>
                    </div>
                </DownloadCard>
            </div>
        </div>
    </section>
	</Layout>
